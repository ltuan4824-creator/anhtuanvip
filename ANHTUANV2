    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Roboto:wght@400;700&display=swap');
        body { background: #0b0518; color: white; font-family: 'Roboto', sans-serif; overflow-x: hidden; }
        .glass { background: rgba(20, 12, 36, 0.95); border: 1px solid rgba(168, 85, 247, 0.15); border-radius: 2rem; }
        .font-vjp { font-family: 'Orbitron', sans-serif; }
        .btn-grad { background: linear-gradient(90deg, #ec4899, #3b82f6); transition: 0.3s; }
        .btn-grad:active { transform: scale(0.95); opacity: 0.9; }
        .input-vjp { width: 100%; background: #160d29; border: 1px solid #2d1b4e; border-radius: 12px; padding: 14px; text-align: center; color: white; outline: none; }
        .contact-item { background: #160d29; border: 1px solid #2d1b4e; border-radius: 12px; padding: 12px; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; font-size: 13px; color: #cbd5e1; text-decoration: none; }
        .hidden { display: none !important; }
        .online-dot { width: 8px; height: 8px; background: #22c55e; border-radius: 50%; box-shadow: 0 0 8px #22c55e; }
        .result-box { background: #1a112e; border: 1px solid #3b82f644; border-radius: 20px; padding: 20px; margin-top: 15px; }
        .dice { width: 35px; height: 35px; background: #2d1b4e; border: 2px solid #ec4899; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: bold; color: #ec4899; font-size: 18px; }
        .result-main { background: linear-gradient(to right, rgba(236, 72, 153, 0.1), rgba(59, 130, 246, 0.1)); border-radius: 12px; padding: 15px; margin: 15px 0; display: flex; justify-content: space-between; align-items: center; }
        .res-badge { padding: 10px 25px; border-radius: 10px; font-weight: 900; font-size: 24px; text-transform: uppercase; border: 2px solid currentColor; }
        .history-card { background: rgba(0, 0, 0, 0.3); border-radius: 15px; padding: 12px; border: 1px solid rgba(255, 255, 255, 0.05); margin-top: 8px; }
        #admin-key-list { max-height: 150px; overflow-y: auto; margin-top: 10px; border-top: 1px solid rgba(16, 185, 129, 0.2); padding-top: 10px; }
        .admin-key-item { background: rgba(0,0,0,0.4); padding: 8px; border-radius: 8px; margin-bottom: 5px; font-size: 10px; display: flex; justify-content: space-between; align-items: center; border: 1px solid rgba(255,255,255,0.05); }
    </style>
</head>
<body class="flex flex-col items-center min-h-screen p-4">

