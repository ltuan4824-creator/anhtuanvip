            <h1 onclick="adminTap()" class="font-vjp text-xl font-bold tracking-tight cursor-pointer uppercase">ANHTUAN VIP</h1>
            <p class="text-[9px] text-slate-400 mt-2">Tool dự đoán Tài Xỉu • 3 xúc sắc xác định • 2 Server</p>
        </div>
        <div class="space-y-4 mb-6">
            <input type="text" id="user-key" placeholder="NHẬP KEY KÍCH HOẠT" class="input-vjp font-mono uppercase text-blue-400">
            <input type="text" id="device-name" placeholder="Tên thiết bị (ví dụ: anhtuan123)" class="input-vjp font-bold">
            <button onclick="checkAccess()" class="w-full py-4 btn-grad rounded-xl font-black text-sm uppercase shadow-lg">Kích Hoạt Key</button>
        </div>
        <div class="mt-8 border-t border-white/5 pt-4">
            <p class="text-center text-[10px] text-amber-500 font-bold uppercase tracking-widest mb-4">Liên Hệ Admin ANHTUAN</p>
            <a href="https://t.me/anhtuanioscrack" target="_blank" class="contact-item"><span>📱</span> Telegram Admin</a>
            <a href="https://t.me/+rWMEb0dwIn1hOGU1" target="_blank" class="contact-item"><span>📢</span> Box Telegram Admin</a>
            <a href="https://zalo.me/0898404060" target="_blank" class="contact-item"><span>💬</span> Zalo Admin ANHTUAN</a>
            <a href="https://zalo.me/g/vpvpzv123" target="_blank" class="contact-item"><span>👥</span> Box Zalo Admin</a>
        </div>
    </div>

    <div id="main-tool" class="w-full max-w-md hidden">
        <div class="glass p-6 border-t-2 border-blue-500">
            <div class="mb-6 p-4 bg-black/40 rounded-2xl text-[10px] space-y-1 font-bold">
                <p class="text-slate-500 uppercase">THIẾT BỊ: <span id="display-device" class="text-white">---</span></p>
                <p class="text-slate-500 uppercase">KEY: <span id="display-key-info" class="text-blue-400">---</span></p>
                <p class="text-rose-400 uppercase">HẠN DÙNG CÒN LẠI:</p>
                <p id="display-expiry" class="text-white font-mono text-lg font-black tracking-widest bg-white/5 p-2 rounded-lg text-center">--:--:--</p>
            </div>
            
            <h2 class="text-center font-vjp text-xs mb-6 tracking-[3px] uppercase">Chọn Server Dự Đoán</h2>
            <div class="space-y-3">
                <div onclick="openPredict(32)" class="bg-[#160d29] p-4 rounded-2xl flex items-center justify-between border border-white/5 cursor-pointer">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-xl bg-blue-600 flex items-center justify-center font-bold uppercase">01</div>
                        <div><p class="font-bold text-xs uppercase">Server 01 • MD5 32</p><p class="text-[8px] text-slate-500 uppercase">32 ký tự • Thuật toán Logic thật</p></div>
                    </div>
                    <span>❯</span>
                </div>
                <div onclick="openPredict(64)" class="bg-[#160d29] p-4 rounded-2xl flex items-center justify-between border border-white/5 cursor-pointer">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-xl bg-orange-600 flex items-center justify-center font-bold uppercase">02</div>
                        <div><p class="font-bold text-xs uppercase">Server 02 • MD5 64</p><p class="text-[8px] text-slate-500 uppercase">64 ký tự • Đối soát SHA-256</p></div>
                    </div>
                    <span>❯</span>
                </div>
            </div>
        </div>
    </div>

    <div id="predict-screen" class="w-full max-w-md hidden">
        <div class="glass p-6 border-t-2 border-pink-500 text-center">
            <p id="sv-label" class="text-[9px] text-slate-500 uppercase mb-1">SERVER 01</p>
            <h2 id="sv-title" class="font-vjp text-lg mb-1 uppercase">MD5 32 KÝ TỰ</h2>
            <input type="text" id="md5-input" placeholder="Dán mã MD5 tại đây..." class="input-vjp mb-4 font-mono mt-4 uppercase">
            <div class="grid grid-cols-2 gap-3 mb-4">
                <button onclick="pasteClipboard()" class="bg-[#160d29] py-3 rounded-xl text-[10px] font-bold border border-white/5 uppercase">📋 Dán Mã</button>
                <button onclick="clearInput()" class="bg-[#160d29] py-3 rounded-xl text-[10px] font-bold border border-white/5 text-rose-400 uppercase">× Xóa Mã</button>
            </div>
            <button onclick="handleAnalyze()" id="btn-run" class="w-full py-4 btn-grad rounded-xl font-black text-xs uppercase shadow-lg">Phân Tích Ngay</button>
            
            <div id="result-area" class="hidden">
                <div class="result-box text-left">
                    <div class="flex justify-center gap-3 mb-4">
                        <div id="dice-1" class="dice">?</div><div id="dice-2" class="dice">?</div><div id="dice-3" class="dice">?</div>
                    </div>
                    <div class="result-main">
                        <div id="badge-res" class="res-badge">---</div>
                        <div class="text-right">
                            <p id="main-pct" class="text-3xl font-black">--%</p>
                            <p id="dice-sum" class="text-[9px] text-slate-400 mt-1 uppercase">Tính toán...</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-left mt-6">
                <div class="flex justify-between items-center mb-2 px-1">
                    <span class="text-[10px] font-bold text-slate-400 uppercase">Lịch sử Server</span>
                    <button onclick="clearHistory()" class="text-[9px] text-rose-500 uppercase font-bold">XÓA</button>
                </div>
                <div id="history-list"></div>
            </div>
            <button onclick="backToMain()" class="mt-8 text-slate-500 text-[10px] font-bold uppercase underline">← Quay Lại</button>
        </div>
    </div>

    <div id="admin-panel" class="w-full max-w-sm glass p-6 mt-4 hidden border-emerald-500/50">
        <h2 class="text-emerald-400 font-bold text-[10px] uppercase mb-4 text-center tracking-widest">Admin Control ANHTUAN</h2>
        <div class="grid grid-cols-3 gap-2 mb-4">
            <button onclick="createKey(24)" class="bg-emerald-500/10 py-2 rounded-lg text-[9px] font-bold">KEY NGÀY</button>
            <button onclick="createKey(168)" class="bg-emerald-500/10 py-2 rounded-lg text-[9px] font-bold">KEY TUẦN</button>
            <button onclick="createKey(720)" class="bg-emerald-500/10 py-2 rounded-lg text-[9px] font-bold">KEY THÁNG</button>
        </div>
        <input id="key-res" readonly class="w-full bg-black/50 border border-emerald-500/20 rounded p-3 text-emerald-400 text-xs text-center mb-2 font-mono uppercase">
        <div class="grid grid-cols-2 gap-2 mb-4">
            <button onclick="copyAdminKey()" class="bg-emerald-500 py-3 rounded-xl text-[10px] font-black uppercase">COPY GỬI KHÁCH</button>
            <button onclick="resetAllKeys()" class="bg-rose-600 py-3 rounded-xl text-[10px] font-black uppercase">RESET & XÓA LỊCH SỬ</button>
        </div>
        <p class="text-[9px] font-bold text-emerald-500/60 uppercase tracking-tighter">Lịch sử tạo Key:</p>
        <div id="admin-key-list"></div>
    </div>

    <script>
        const ADMIN_PASS = "anhtuan09032010";
        let tapCount = 0, currentTarget = 32, history = [], timerInterval, activeKey = "";

        // --- HỆ THỐNG ADMIN ---
        function adminTap() {
            tapCount++;
            if(tapCount >= 10) {
                if(prompt("PASS ADMIN:") === ADMIN_PASS) {
                    document.getElementById('admin-panel').classList.toggle('hidden');
                    renderAdminKeyList();
                }
                tapCount = 0;
            }
        }

        function createKey(h) {
            const prefix = h === 24 ? "NGAY" : (h === 168 ? "TUAN" : "THANG");
            const k = `${prefix}-${Math.random().toString(36).substring(2,8).toUpperCase()}`;
            let db = JSON.parse(localStorage.getItem('at_db_secure') || '{}');
            db[k] = { hours: h, expiry: null, device: null };
            localStorage.setItem('at_db_secure', JSON.stringify(db));
            document.getElementById('key-res').value = k;
            renderAdminKeyList();
        }

        function renderAdminKeyList() {
            const list = document.getElementById('admin-key-list');
            let db = JSON.parse(localStorage.getItem('at_db_secure') || '{}');
            list.innerHTML = '';
            Object.keys(db).reverse().forEach(key => {
                const info = db[key];
                list.innerHTML += `<div class="admin-key-item"><div class="flex flex-col"><span class="font-mono text-emerald-400">${key}</span><span class="text-[7px] text-slate-400">Dùng: ${info.device || 'Chưa có'}</span></div><button onclick="copySpecificKey('${key}')" class="bg-emerald-500/20 px-2 py-1 rounded text-emerald-300">Copy</button></div>`;
            });
        }

        function copySpecificKey(k) { navigator.clipboard.writeText(k); alert("Đã copy: " + k); }
        function resetAllKeys() { if(confirm("Xóa sạch dữ liệu?")) { localStorage.removeItem('at_db_secure'); location.reload(); } }
        function copyAdminKey() { const o = document.getElementById('key-res'); o.select(); document.execCommand('copy'); alert("Đã copy key!"); }

        // --- HỆ THỐNG ĐĂNG NHẬP ---
        function checkAccess() {
            const k = document.getElementById('user-key').value.trim().toUpperCase();
            const n = document.getElementById('device-name').value.trim();
            let db = JSON.parse(localStorage.getItem('at_db_secure') || '{}');
            if(n.length < 6) return alert("Tên thiết bị > 6 ký tự!");
            if(k === ADMIN_PASS.toUpperCase()) {
                activeKey = k; startTimer(new Date().getTime() + 999999999);
                document.getElementById('display-device').innerText = n;
                document.getElementById('display-key-info').innerText = "ADMIN ACCESS";
                document.getElementById('login-screen').classList.add('hidden');
                document.getElementById('main-tool').classList.remove('hidden');
                return;
            }
            if(db[k]) {
                if(db[k].device && db[k].device !== n) return alert("Key đã khóa cho thiết bị khác!");
                if(!db[k].device) { db[k].device = n; db[k].expiry = new Date().getTime() + (db[k].hours * 60 * 60 * 1000); localStorage.setItem('at_db_secure', JSON.stringify(db)); }
                if (new Date().getTime() > db[k].expiry) return alert("Key hết hạn!");
                activeKey = k; startTimer(db[k].expiry);
                document.getElementById('display-device').innerText = n;
                document.getElementById('display-key-info').innerText = k;
                document.getElementById('login-screen').classList.add('hidden');
                document.getElementById('main-tool').classList.remove('hidden');
            } else { alert("Key sai!"); }
        }

        function startTimer(expiry) {
            timerInterval = setInterval(() => {
                let distance = expiry - new Date().getTime();
                if (distance < 0) { clearInterval(timerInterval); location.reload(); return; }
                let d = Math.floor(distance / (1000 * 60 * 60 * 24)), h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)), m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60)), s = Math.floor((distance % (1000 * 60)) / 1000);
                document.getElementById('display-expiry').innerText = (d > 0 ? d + "N " : "") + String(h).padStart(2, '0') + ":" + String(m).padStart(2, '0') + ":" + String(s).padStart(2, '0');
            }, 1000);
        }

        // --- BỘ NÃO PHÂN TÍCH MD5 THẬT (VIP) ---
        function handleAnalyze() {
            const val = document.getElementById('md5-input').value.trim();
            if(val.length !== currentTarget) return alert(`Nhập đúng ${currentTarget} ký tự!`);
            const btn = document.getElementById('btn-run');
            btn.innerText = "ĐANG GIẢI MÃ MD5..."; btn.disabled = true;

            setTimeout(() => {
                // Thuật toán Logic Trọng Số: 1 mã ra 1 kết quả cố định
                let weight = 0;
                // Bóc tách mã ASCII tại các vị trí chốt
                const anchors = [0, 5, 10, 15, 20, val.length - 1];
                anchors.forEach(pos => weight += val.charCodeAt(pos) || 0);

                const isTai = (weight % 2 === 0);
                
                // Tạo xí ngầu dựa trên 3 ký tự cuối của mã MD5 (Đảm bảo đồng nhất)
                let d1 = (val.charCodeAt(val.length-1) % 6) + 1;
                let d2 = (val.charCodeAt(val.length-2) % 6) + 1;
                let d3 = (val.charCodeAt(val.length-3) % 6) + 1;
                let sum = d1 + d2 + d3;

                // Cân bằng xí ngầu theo kết quả giải thuật
                if (isTai && sum <= 10) { d1 = 6; d2 = 5; d3 = 4; sum = 15; }
                if (!isTai && sum > 10) { d1 = 1; d2 = 2; d3 = 3; sum = 6; }

                const confidence = 85 + (weight % 13);
                const res = { type: isTai?'tài':'xỉu', pct: confidence + "%", dices: [d1, d2, d3], sum: sum, time: new Date().toLocaleTimeString('vi-VN'), code: val.substring(0, 12) + "..." };

                document.getElementById('badge-res').innerText = res.type;
                document.getElementById('badge-res').className = `res-badge ${isTai?'text-blue-500':'text-pink-500'}`;
                document.getElementById('main-pct').innerText = res.pct;
                document.getElementById('dice-1').innerText = d1;
                document.getElementById('dice-2').innerText = d2;
                document.getElementById('dice-3').innerText = d3;
                document.getElementById('dice-sum').innerText = `Tổng: ${sum} • ${d1}+${d2}+${d3}`;
                document.getElementById('result-area').classList.remove('hidden');
                
                history.unshift(res); renderHistory();
                btn.innerText = "Phân Tích Ngay"; btn.disabled = false;
            }, 1800);
        }

        function renderHistory() {
            const list = document.getElementById('history-list');
            list.innerHTML = history.length ? '' : '<p class="text-center text-[10px] text-slate-600 mt-4 italic">Trống</p>';
            history.forEach(item => {
                list.innerHTML += `<div class="history-card flex items-center justify-between"><div class="flex items-center gap-3"><div class="px-3 py-1 rounded-lg text-[9px] font-black uppercase ${item.type==='tài'?'bg-blue-600':'bg-pink-600'}">${item.type}</div><div class="text-[9px]"><p class="text-white font-mono">${item.code}</p><p class="text-slate-500">${item.time} • Tổng:${item.sum}</p></div></div><div class="text-emerald-400 font-bold text-xs">${item.pct}</div></div>`;
            });
        }

        function openPredict(len) { currentTarget = len; document.getElementById('main-tool').classList.add('hidden'); document.getElementById('predict-screen').classList.remove('hidden'); document.getElementById('sv-label').innerText = `SERVER 0${len==32?1:2}`; document.getElementById('sv-title').innerText = `MD5 ${len} KÝ TỰ`; document.getElementById('result-area').classList.add('hidden'); renderHistory(); }
        async function pasteClipboard() { try { document.getElementById('md5-input').value = await navigator.clipboard.readText(); } catch(e) {} }
        function clearInput() { document.getElementById('md5-input').value = ""; document.getElementById('result-area').classList.add('hidden'); }
        function clearHistory() { history = []; renderHistory(); }
        function backToMain() { document.getElementById('predict-screen').classList.add('hidden'); document.getElementById('main-tool').classList.remove('hidden'); }
    </script>
</body>
